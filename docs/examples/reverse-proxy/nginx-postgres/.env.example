OVUMCY_IMAGE=ghcr.io/terraincognita07/ovumcy:v0.6.0
TZ=UTC
DEFAULT_LANGUAGE=en
SECRET_KEY=replace-with-a-strong-32-byte-secret
POSTGRES_DB=ovumcy
POSTGRES_USER=ovumcy
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_LOGIN_WINDOW=15m
RATE_LIMIT_FORGOT_PASSWORD_MAX=8
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=1h
RATE_LIMIT_API_MAX=300
RATE_LIMIT_API_WINDOW=1m
