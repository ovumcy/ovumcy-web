# Replace the placeholder domain with your real public hostname before running this stack.

ovumcy.example.com {
	encode zstd gzip
	reverse_proxy ovumcy:8080 {
		# Set X-Real-IP to the direct client IP so the app's per-IP rate limiter
		# keys on an unspoofable value (PROXY_HEADER=X-Real-IP). Caddy also sets
		# X-Forwarded-For, but the app must not key on that: it appends the
		# client-supplied value and the leftmost entry would be attacker-controlled.
		header_up X-Real-IP {remote_host}
	}
}
