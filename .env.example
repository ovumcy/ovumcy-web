# Required in all deployments: set one strong secret source before first start.
# SECRET_KEY takes precedence if both are set.
# SECRET_KEY_FILE must point to a readable in-container path, for example /run/secrets/ovumcy_secret_key.
SECRET_KEY=
SECRET_KEY_FILE=

# Core behavior (recommended defaults)
TZ=UTC
# Supported: en, ru, es, fr, de
DEFAULT_LANGUAGE=en
REGISTRATION_MODE=open
DB_DRIVER=sqlite
DB_PATH=data/ovumcy.db
# Internal app port. Public HTTPS deployments should expose only the proxy.
PORT=8080
HOST_BIND_ADDRESS=127.0.0.1

# Local/private base compose profile
COOKIE_SECURE=false
TRUST_PROXY_ENABLED=false
PROXY_HEADER=X-Forwarded-For
TRUSTED_PROXIES=127.0.0.1,::1

# Public reverse-proxy stack profile
# Use the example stacks under docs/examples/reverse-proxy/ and adapt:
# COOKIE_SECURE=true
# TRUST_PROXY_ENABLED=true
# PROXY_HEADER=X-Forwarded-For
# TRUSTED_PROXIES=<exact proxy IP or private subnet>
# Leave HOST_BIND_ADDRESS at 127.0.0.1 for the base compose path.

# Advanced rate limits (self-host safe defaults)
RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_LOGIN_WINDOW=15m
RATE_LIMIT_FORGOT_PASSWORD_MAX=8
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=1h
RATE_LIMIT_API_MAX=300
RATE_LIMIT_API_WINDOW=1m

# Advanced optional Postgres path
# DB_DRIVER=postgres
# DATABASE_URL=postgres://ovumcy:change-me@127.0.0.1:5432/ovumcy?sslmode=disable
