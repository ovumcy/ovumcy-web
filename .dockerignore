# Test code must stay in the public repo but never ship in the runtime image.
# The build runs only `go build`, which ignores these; CI tests from a repo
# checkout, not the Docker context. Runtime assets (templates, i18n locales,
# web/static) are embedded into the binary via go:embed, which matches only the
# asset globs and never *_test.go — this exclusion keeps test sources out of the
# build context as defense in depth.
**/*_test.go
**/testdata/
.mutation/

.idea/
.vscode/

.tmp_*/
.tmp*/

docker/
web/src/
scripts/
package.json
package-lock.json
tailwind.config.js
eslint.config.mjs
playwright.config.ts
