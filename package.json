{
  "name": "ovumcy-assets",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "node ./scripts/build-css.mjs",
    "build:js": "node ./scripts/build-js.mjs",
    "build": "npm run build:css && npm run build:js",
    "lint": "npm run lint:js",
    "lint:js": "eslint --max-warnings=0 web/src/js web/static/js/chart-lite.js scripts/build-js.mjs scripts/build-css.mjs scripts/run-e2e.mjs",
    "e2e": "node ./scripts/run-e2e.mjs --mode=stable",
    "e2e:ci": "node ./scripts/run-e2e.mjs --mode=ci",
    "e2e:fast": "node ./scripts/run-e2e.mjs --mode=fast",
    "e2e:postgres": "node ./scripts/run-e2e.mjs --mode=stable --db=postgres",
    "e2e:ci:postgres": "node ./scripts/run-e2e.mjs --mode=ci --db=postgres",
    "e2e:fast:postgres": "node ./scripts/run-e2e.mjs --mode=fast --db=postgres"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "alpinejs": "^3.14.8",
    "eslint": "^10.0.1",
    "globals": "^15.15.0",
    "htmx.org": "^1.9.12",
    "tailwindcss": "^3.4.17"
  }
}
